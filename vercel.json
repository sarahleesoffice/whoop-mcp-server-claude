{
  "version": 2,
  "functions": {
    "api/mcp.ts": {
      "maxDuration": 300
    },
    "api/index.ts": {
      "maxDuration": 10
    },
    "api/auth/callback.ts": {
      "maxDuration": 300
    }
  },
  "rewrites": [
    {
      "source": "/",
      "destination": "/api/index"
    },
    {
      "source": "/mcp",
      "destination": "/api/mcp"
    }
  ]
}
